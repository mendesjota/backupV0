microsteps = 32
endstop_pin = ^PC4
position_endstop = 119.6
position_max = 119.6
position_min = 0
homing_speed = 20
second_homing_speed = 3.0
homing_retract_dist = 3.0

[tmc2209 stepper_z]
uart_pin = PB3
uart_address = 2
interpolate = False
run_current = 0.3
sense_resistor = 0.220
stealthchop_threshold = 0

[extruder]
step_pin = PB2
dir_pin = !PA15
enable_pin = !PD2
full_steps_per_rotation = 200
rotation_distance = 22.40
gear_ratio = 50:10
microsteps = 32
nozzle_diameter = 0.400
filament_diameter = 1.750
heater_pin = PC7
sensor_type = Generic 3950
sensor_pin = PC5
min_temp = 0
max_temp = 280
min_extrude_temp = 170
max_extrude_only_distance = 150
max_extrude_cross_section = 5.0
pressure_advance = 0.0
pressure_advance_smooth_time = 0.040
control = pid
pid_kp = 27.029
pid_ki = 1.133
pid_kd = 161.158

[tmc2209 extruder]
uart_pin = PB3
uart_address = 3
interpolate = False
run_current = 0.4
sense_resistor = 0.220
stealthchop_threshold = 0

[firmware_retraction]
retract_length = 0.8
retract_speed = 40
unretract_extra_length = 0
unretract_speed = 40

[verify_heater extruder]
max_error = 150
check_gain_time = 40
hysteresis = 10
heating_gain = 2

[heater_bed]
heater_pin = PC8
sensor_type = Generic 3950
sensor_pin = PB0
smooth_time = 3.0
min_temp = 0
max_temp = 120
control = pid
pid_kp = 65.665
pid_ki = 3.367
pid_kd = 320.117

[heater_fan hotend_fan]
pin = PA13
max_power = 1.0
kick_start_time = 0.5
heater = extruder
heater_temp = 50.0

[fan]
pin = PA14
max_power = 1.0
kick_start_time = 0.5
off_below = 0.13
cycle_time = 0.010

[temperature_fan btt_pi]
pin = PA8
max_power = 1
shutdown_speed = 0.0
cycle_time = 0.01
hardware_pwm = False
kick_start_time = 0
sensor_type = temperature_host
min_temp = 10
max_temp = 80
target_temp = 45
max_speed = 1
min_speed = 0.0
control = pid
pid_kp = 2.0
pid_ki = 5.0
pid_kd = 0.5
pid_deriv_time = 2.0
gcode_id = pi

[idle_timeout]
timeout = 36000

[homing_override]
gcode = 
	_HOME_X
	_HOME_Y
	G28 Z

[bed_screws]
screw1 = 60,5
screw1_name = front screw
screw2 = 5,115
screw2_name = back left
screw3 = 115,115
screw3_name = back right

[neopixel board_rgb]
pin = PC9
chain_count = 1
color_order = GRB
initial_red = 0.0
initial_green = 0.1
initial_blue = 0.0

[gcode_macro PRINT_START]
gcode = 
	{% set BED_TEMP = params.BED_TEMP|default(60)|float %}
	{% set EXTRUDER_TEMP = params.EXTRUDER_TEMP|default(190)|float %}
	
	G90
	G92 E0
	
	
	M140 S{BED_TEMP}
	M104 S{EXTRUDER_TEMP}
	
	
	_CG28
	G28 Z
	G90
	
	
	M190 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}
	
	
	G1 Z5 F3000
	VORON_PURGE
	
	G92 E0

[gcode_macro PRINT_END]
gcode = 
	TURN_OFF_HEATERS
	G91
	G1 Z10 F1500
	G1 E-1 F3000
	G90
	G1 X100 Y100 F3000
	M106 S0
	SET_STEPPER_ENABLE STEPPER=extruder ENABLE=0
	BED_MESH_CLEAR

[gcode_macro _HOME_X]
gcode = 
	
	{% set RUN_CURRENT_X = printer.configfile.settings['tmc2209 stepper_x'].run_current|float %}
	{% set RUN_CURRENT_Y = printer.configfile.settings['tmc2209 stepper_y'].run_current|float %}
	{% set HOME_CURRENT_X = RUN_CURRENT_X / 2 %}
	{% set HOME_CURRENT_Y = RUN_CURRENT_Y / 2 %}
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={HOME_CURRENT_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={HOME_CURRENT_Y}
	
	set_tmc_field stepper=stepper_x field=tcoolthrs value=1048575
	set_tmc_field stepper=stepper_y field=tcoolthrs value=1048575
	
	
	G28 X
	
	G91
	G1 X-10 F1200
	
	
	G4 P100
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={RUN_CURRENT_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={RUN_CURRENT_Y}

[gcode_macro _HOME_Y]
gcode = 
	
	{% set RUN_CURRENT_X = printer.configfile.settings['tmc2209 stepper_x'].run_current|float %}
	{% set RUN_CURRENT_Y = printer.configfile.settings['tmc2209 stepper_y'].run_current|float %}
	{% set HOME_CURRENT_X = RUN_CURRENT_X / 2 %}
	{% set HOME_CURRENT_Y = RUN_CURRENT_Y / 2 %}
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={HOME_CURRENT_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={HOME_CURRENT_Y}
	
	set_tmc_field stepper=stepper_x field=tcoolthrs value=1048575
	set_tmc_field stepper=stepper_y field=tcoolthrs value=1048575
	
	
	G28 Y
	
	G91
	G1 Y-10 F1200
	
	
	G4 P1000
	
	SET_TMC_CURRENT STEPPER=stepper_x CURRENT={RUN_CURRENT_X}
	SET_TMC_CURRENT STEPPER=stepper_y CURRENT={RUN_CURRENT_Y}

[gcode_macro M600]
gcode = 
	SAVE_GCODE_STATE NAME=M600_state
	PAUSE
	M300
	G91
	G1 E-50 F1000
	M300
	M300
	RESTORE_GCODE_STATE NAME=M600_state

[gcode_macro _CG28]
gcode = 
	{% if "xyz" not in printer.toolhead.homed_axes %}
	G28
	{% endif %}

[gcode_macro LOAD_FILAMENT]
gcode = 
	M83
	G1 E30 F300
	G1 E15 F150
	M82

[gcode_macro UNLOAD_FILAMENT]
gcode = 
	M83
	G1 E10 F300
	G1 E-40 F1800
	M82
